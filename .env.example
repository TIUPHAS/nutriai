# Copie este arquivo para .env e preencha com seus valores reais
# O arquivo .env NUNCA deve ser enviado ao GitHub
# Gere uma SECRET_KEY segura com: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=troque_por_uma_chave_secreta_longa_e_aleatoria_minimo_32_chars
GROQ_API_KEY=sua_chave_groq_aqui
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco
ALLOWED_ORIGINS=https://seu-frontend.onrender.com,http://localhost:5500

# Nível de log: DEBUG, INFO, WARNING, ERROR (padrão: INFO)
LOG_LEVEL=INFO
